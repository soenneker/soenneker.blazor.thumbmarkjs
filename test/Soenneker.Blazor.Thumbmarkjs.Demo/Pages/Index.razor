@page "/"
@using System.Text.Json
@using Microsoft.Extensions.Logging
@inject ILogger<Index> Logger

<Thumbmarkjs @ref="_thumbmarkjs"
             OnGenerated="OnGenerated"
             OnDataGenerated="OnDataGenerated" />

<Div Space="Space.Y.Is6">
    <Grid Columns="Columns.Is1.OnMd.Is2" Gap="Gap.Is4">
        <DemoPanel Title="Thumbmark" Description="One-shot hash from the browser fingerprint.">
            @if (string.IsNullOrWhiteSpace(Thumbmark))
            {
                <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Run Get to compute the thumbmark.</Paragraph>
            }
            else
            {
                <Field>
                    <FieldLabel>Hash</FieldLabel>
                    <FieldBody>
                        <Input Value="@Thumbmark" ReadOnly="true" />
                    </FieldBody>
                </Field>
            }
            <DemoButtonRow>
                <Button OnClick="Get" Disabled="@IsLoading">@(IsLoading ? "Loading…" : "Get")</Button>
            </DemoButtonRow>
        </DemoPanel>

        <DemoPanel Title="Thumbmark data" Description="Detailed JSON payload from the library.">
            @if (string.IsNullOrWhiteSpace(ThumbmarkData))
            {
                <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Run Get detailed data.</Paragraph>
            }
            else
            {
                <PreCode Class="demo-pre" Highlight="false">@ThumbmarkData</PreCode>
            }
            <DemoButtonRow>
                <Button OnClick="GetData" Variant="ButtonVariant.Secondary" Disabled="@IsLoading">Get detailed data</Button>
            </DemoButtonRow>
        </DemoPanel>
    </Grid>
</Div>

@code {
    private string? Thumbmark { get; set; }
    private string? ThumbmarkData { get; set; }
    private bool IsLoading { get; set; }

    private Thumbmarkjs? _thumbmarkjs;

    private async Task Get()
    {
        if (_thumbmarkjs is null)
            return;

        try
        {
            IsLoading = true;
            Thumbmark = await _thumbmarkjs.Get();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task GetData()
    {
        if (_thumbmarkjs is null)
            return;

        try
        {
            IsLoading = true;

            JsonElement? data = await _thumbmarkjs.GetData();

            ThumbmarkData = data.HasValue
                ? JsonSerializer.Serialize(data.Value, new JsonSerializerOptions { WriteIndented = true })
                : null;
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private void OnGenerated(string thumbmark)
    {
        Logger.LogInformation("OnGenerated: {Thumbmark}", thumbmark);
    }

    private void OnDataGenerated(JsonElement data)
    {
        Logger.LogInformation("OnDataGenerated: {Data}", data.ToString());
    }
}
